model Transaction {
    id         Int      @id @default(autoincrement())
    title      String
    amount     Decimal
    type       TRansactionType @default(OUTCOME)
    categoryId Int
    category   Category @relation(fields: [categoryId], references: [id])
    userId     String
    user       User     @relation(fields: [userId], references: [id])
}

enum TRansactionType {
    INCOME
    OUTCOME
}